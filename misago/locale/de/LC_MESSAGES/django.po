#: conf/admin/__init__.py:80
msgctxt "admin node"
msgid "Setup protection against automatic registrations on the site."
msgstr ""
"Richten Sie einen Schutz gegen automatische Registrierungen auf der Website "
"ein."

#: conf/admin/__init__.py:87
msgctxt "admin node"
msgid "Threads"
msgstr "Threads"

#: conf/admin/__init__.py:89
msgctxt "admin node"
msgid "Threads, posts, polls and attachments options."
msgstr "Optionen für Threads, Beiträge, Umfragen und Anhänge."

#: conf/admin/__init__.py:96
msgctxt "admin node"
msgid "Notifications"
msgstr "Benachrichtigungen"

#: conf/admin/__init__.py:99
msgctxt "admin node"
msgid ""
"Those settings control default notification preferences of new user accounts"
" and storage time of existing notifications."
msgstr ""
"Diese Einstellungen legen die Standardbenachrichtigungseinstellungen für "
"neue Benutzerkonten sowie die Aufbewahrungsdauer bestehender "
"Benachrichtigungen fest."

#: conf/admin/__init__.py:106
msgctxt "admin node"
msgid "OAuth2"
msgstr "OAuth2"

#: conf/admin/__init__.py:109
msgctxt "admin node"
msgid "Enable OAuth2 client and connect your site to existing auth provider."
msgstr ""
"Aktivieren Sie den OAuth2-Client und verbinden Sie Ihre Website mit einem "
"bestehenden Authentifizierungsanbieter."

#: conf/admin/__init__.py:116
msgctxt "admin node"
msgid "Analytics"
msgstr "Statistik"

#: conf/admin/__init__.py:119
msgctxt "admin node"
msgid "Enable Google Analytics or setup Google Site Verification."
msgstr ""
"Aktivieren Sie Google Analytics oder richten Sie die Google-Website-"
"Verifizierung ein."

#: conf/admin/forms/analytics.py:17
msgctxt "admin analytics settings form"
msgid "Tracking ID"
msgstr "Tracking ID"

#: conf/admin/forms/analytics.py:20
msgctxt "admin analytics settings form"
msgid ""
"Setting the Tracking ID will result in gtag.js file being included in your "
"site's HTML markup, enabling Google Analytics integration."
msgstr ""
"Durch das Festlegen der Tracking-ID wird die Datei „gtag.js“ in den HTML-"
"Code Ihrer Website eingebunden, wodurch die Integration von Google Analytics"
" ermöglicht wird."

#: conf/admin/forms/analytics.py:25
msgctxt "admin analytics settings form"
msgid "Site verification code"
msgstr "Bestätigungscode für die Website"

#: conf/admin/forms/analytics.py:28
msgctxt "admin analytics settings form"
msgid ""
"This code was extracted from the uploaded site verification file. To change "
"it, upload new verification file."
msgstr ""
"Dieser Code wurde aus der hochgeladenen Datei zur Website-Verifizierung "
"extrahiert. Um ihn zu ändern, laden Sie bitte eine neue Verifizierungsdatei "
"hoch."

#: conf/admin/forms/analytics.py:35
msgctxt "admin analytics settings form"
msgid "Upload site verification file"
msgstr "Website-Verifizierungsdatei hochladen"

#: conf/admin/forms/analytics.py:39
msgctxt "admin analytics settings form"
msgid ""
"Site verification file can be downloaded from Search Console's \"Ownership "
"verification\" page."
msgstr ""
"Die Datei zur Website-Verifizierung kann auf der Seite „Ownership "
"verification“ der Suchkonsole heruntergeladen werden."

#: conf/admin/forms/analytics.py:52
msgctxt "admin analytics settings form"
msgid "Uploaded file type is not HTML."
msgstr "Der hochgeladene Dateityp ist nicht HTML."

#: conf/admin/forms/analytics.py:62
msgctxt "admin analytics settings form"
msgid "Uploaded file doesn't contain a verification code."
msgstr "Die hochgeladene Datei enthält keinen Verifizierungscode."

#: conf/admin/forms/captcha.py:21
