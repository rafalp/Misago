"Username can only contain Latin alphabet letters, digits, and an underscore "
"sign."
msgstr ""
"Der Benutzername darf nur Buchstaben des lateinischen Alphabets, Ziffern und"
" Unterstriche enthalten."

#: users/validators.py:111
msgctxt "username validator"
msgid "Username must contain Latin alphabet letters or digits."
msgstr ""
"Der Benutzername muss Buchstaben des lateinischen Alphabets oder Ziffern "
"enthalten."

#: users/validators.py:120
#, python-format
msgctxt "username length validator"
msgid "Username must be at least %(limit_value)s character long."
msgid_plural "Username must be at least %(limit_value)s characters long."
msgstr[0] ""
"Der Benutzername muss mindestens %(limit_value)s Zeichen lang sein."
msgstr[1] ""
"Der Benutzername muss mindestens %(limit_value)s Zeichen lang sein."

#: users/validators.py:129
#, python-format
msgctxt "username length validator"
msgid "Username cannot be longer than %(limit_value)s characters."
msgid_plural "Username cannot be longer than %(limit_value)s characters."
msgstr[0] ""
"Der Benutzername kann nicht länger als %(limit_value)s Zeichen sein."
msgstr[1] ""
"Der Benutzername kann nicht länger als %(limit_value)s Zeichen sein."

#: users/validators.py:168
msgctxt "stop forum spam validator"
msgid "Data entered was found in spammers database."
msgstr "Die eingegebenen Daten wurden in einer Spammer-Datenbank gefunden."

#: users/validators.py:183
msgctxt "gmail email validator"
msgid "This e-mail is not allowed."
msgstr "Diese E-Mail ist nicht zulässig."

#: users/views/activation.py:23
